// Configuración de Generador y DB
generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- MODELOS DE USUARIO Y SEGURIDAD ---

enum Role {
  USER
  ADMIN
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String?
  role      Role     @default(USER)
  modules   String[] @default(["FINANCE"])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones
  wallets     Wallet[]
  investments Investment[]
  bets        Bet[]
  categories  Category[]
  // Collections Module
  collectionCategories    CollectionCategory[]
  collectionSubcategories CollectionSubcategory[]
  collectionItems         CollectionItem[]
  // Tipster Module
  tipsterBank             TipsterBank?
  tipsterBets             TipsterBet[]

  // Wiki Module
  wikiFolders WikiFolder[]
  wikiTopics  WikiTopic[]
  wikiNotes   WikiNote[]

  // Investment Platforms
  investmentPlatforms InvestmentPlatform[]
}

// --- MÓDULO DE FINANZAS (PLATA) ---

enum WalletType {
  GENERAL
  BETTING
}

model Wallet {
  id                String        @id @default(uuid())
  name              String        // Ej: "Ahorros BCP", "Efectivo", "Binance"
  balance           Decimal       @default(0) @db.Decimal(15, 2)
  currency          String        @default("PEN")
  type              WalletType    @default(GENERAL)
  userId            String
  user              User          @relation(fields: [userId], references: [id])
  transactions      Transaction[] @relation("WalletToTransaction")
  incomingTransfers Transaction[] @relation("TargetWalletToTransaction")
  bets              Bet[]
}

model Category {
  id           String          @id @default(uuid())
  name         String
  type         TransactionType // INCOME o EXPENSE
  userId       String
  user         User            @relation(fields: [userId], references: [id])
  transactions Transaction[]
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
}

model Transaction {
  id             String          @id @default(uuid())
  amount         Decimal         @db.Decimal(15, 2)
  description    String
  date           DateTime        @default(now())
  type           TransactionType
  walletId       String
  wallet         Wallet          @relation("WalletToTransaction", fields: [walletId], references: [id])
  targetWalletId String?
  targetWallet   Wallet?         @relation("TargetWalletToTransaction", fields: [targetWalletId], references: [id])
  categoryId     String?
  category       Category?       @relation(fields: [categoryId], references: [id])
}

// --- MÓDULO DE INVERSIONES ---

model Investment {
  id            String   @id @default(uuid())
  assetName     String   // Ej: "Bitcoin", "Tienda de Ropa"
  symbol        String?  // Ej: "BTC"
  coingeckoId   String?  // Id para la API de CoinGecko
  type          String   // "CRIPTO", "NEGOCIO", "ACCION"
  initialAmount Decimal  @db.Decimal(15, 2)
  currentValue  Decimal  @db.Decimal(15, 2)
  
  userId        String
  user          User     @relation(fields: [userId], references: [id])

  platformId    String?
  platform      InvestmentPlatform? @relation(fields: [platformId], references: [id])
  
  transactions  InvestmentTransaction[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model InvestmentPlatform {
  id          String   @id @default(uuid())
  name        String   // Ej: "Binance", "MetaMask", "Efectivo"
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  investments Investment[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model InvestmentTransaction {
  id           String   @id @default(uuid())
  type         String   // "BUY", "SELL"
  amount       Decimal  @db.Decimal(20, 8)
  priceAtDate  Decimal  @db.Decimal(20, 8)
  date         DateTime @default(now())
  
  investmentId String
  investment   Investment @relation(fields: [investmentId], references: [id])
}

// --- MÓDULO WIKI (APUNTES) ---

model WikiFolder {
  id        String      @id @default(uuid())
  name      String
  userId    String
  user      User        @relation(fields: [userId], references: [id])
  topics    WikiTopic[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

model WikiTopic {
  id        String     @id @default(uuid())
  name      String
  folderId  String
  folder    WikiFolder @relation(fields: [folderId], references: [id])
  notes     WikiNote[]
  userId    String
  user      User       @relation(fields: [userId], references: [id])
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model WikiNote {
  id        String    @id @default(uuid())
  title     String
  content   String    @db.Text
  topicId   String
  topic     WikiTopic @relation(fields: [topicId], references: [id])
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

// --- MÓDULO DE APUESTAS ---

model Bet {
  id        String    @id @default(uuid())
  event     String // Ej: "Real Madrid vs Barcelona"
  sport     String    @default("Fútbol")
  stake     Decimal   @db.Decimal(15, 2)
  odds      Decimal   @db.Decimal(5, 2)
  status    BetStatus @default(PENDING)
  result    Decimal?  @db.Decimal(15, 2) // Ganancia neta calculada
  createdAt DateTime  @default(now())
  userId    String
  user      User      @relation(fields: [userId], references: [id])  
  walletId  String?
  wallet    Wallet?   @relation(fields: [walletId], references: [id])
}

enum BetStatus {
  PENDING
  WON
  LOST
  VOID
  CASHOUT
}

// --- MÓDULO COLECCIONES UNIVERSALES ---

model CollectionCategory {
  id     String @id @default(uuid())
  name   String // Ej: "Monedas", "Billetes", "Estampillas"
  userId String
  user   User   @relation(fields: [userId], references: [id])
  
  subcategories CollectionSubcategory[]
  items         CollectionItem[]
}

model CollectionSubcategory {
  id         String @id @default(uuid())
  name       String // Ej: "Riqueza y Orgullo", "Fauna Silvestre"
  categoryId String
  category   CollectionCategory @relation(fields: [categoryId], references: [id])
  userId     String
  user       User   @relation(fields: [userId], references: [id])

  items      CollectionItem[]
}

model CollectionItem {
  id             String        @id @default(uuid())
  name           String        // Ej: "1 Sol - Machu Picchu"
  year           Int?          // Opcional para otros objetos
  quality        String?       // Opcional
  quantity       Int           @default(1)
  estimatedValue Decimal?      @db.Decimal(15, 2)
  
  categoryId     String
  category       CollectionCategory  @relation(fields: [categoryId], references: [id])
  
  subcategoryId  String?
  subcategory    CollectionSubcategory? @relation(fields: [subcategoryId], references: [id])
  
  userId         String
  user           User          @relation(fields: [userId], references: [id])
  createdAt      DateTime      @default(now())
}

// --- MÓDULO GESTIÓN DE BANKROLL (TIPSTERS) ---

model TipsterBank {
  id          String   @id @default(uuid())
  initialBank Decimal  @db.Decimal(15, 2)
  currentBank Decimal  @db.Decimal(15, 2)
  unitValue   Decimal  @default(100) @db.Decimal(15, 2) // Valor inicial de la unidad (referencia)
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id])
  updatedAt   DateTime @updatedAt
}

model TipsterBet {
  id               String    @id @default(uuid())
  date             DateTime  @default(now())
  tipster          String    // Ej: "Sergi", "Personalizado"
  event            String    // "Jodar", "Palomero"
  status           BetStatus @default(PENDING) // Usamos el enum existente de Bets (PENDING, WON, LOST, VOID, CASHOUT)
  
  // Parámetros de ingreso
  stake            Decimal   @db.Decimal(20, 8) // Stake indicado por el tipster
  odds             Decimal   @db.Decimal(20, 8)  // Cuota
  
  // Resultados calculados
  unitsProfit      Decimal?  @db.Decimal(20, 8) // Unidades G/P (e.g. +0.66, -1.0)
  amountWagered    Decimal   @default(0) @db.Decimal(20, 8) // Dinero apostado real (= Stake * UnitValue o asig explícitamente)
  realProfit       Decimal?  @db.Decimal(20, 8) // Ganancia / Pérdida en dinero
  cumulativeBalance Decimal? @db.Decimal(20, 8) // Estado del bank histórico tras esta apuesta
  
  userId           String
  user             User      @relation(fields: [userId], references: [id])
}
